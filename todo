  <!-- ============================================================
       APPLICATION LOGIC
  ============================================================ -->
  <script>
  'use strict';

  /* =========================================================
     1. CONSTANTS & STATE
  ========================================================= */
  const STORAGE_KEY = 'karthika_taskflow_v1';

  // App state
  let state = {
    tasks: [],          // Array of task objects
    filter: 'all',      // 'all' | 'active' | 'completed'
    sort: 'created-desc',
    search: '',
  };

  // Undo buffer (last deleted task)
  let undoBuffer = null;

  /* =========================================================
     2. PERSISTENCE (localStorage)
  ========================================================= */
  function saveToStorage() {
    try {
      localStorage.setItem(STORAGE_KEY, JSON.stringify(state.tasks));
    } catch (e) {
      console.warn('localStorage unavailable:', e);
    }
  }

  function loadFromStorage() {
    try {
      const raw = localStorage.getItem(STORAGE_KEY);
      if (raw) state.tasks = JSON.parse(raw);
    } catch (e) {
      console.warn('Could not load from localStorage:', e);
      state.tasks = [];
    }
  }

  /* =========================================================
     3. TASK DATA MODEL
  ========================================================= */
  function createTask(title, note = '', priority = 'medium', dueDate = '') {
    return {
      id: crypto.randomUUID ? crypto.randomUUID() : Date.now() + Math.random().toString(36),
      title: title.trim(),
      note: note.trim(),
      priority,           // 'high' | 'medium' | 'low'
      dueDate,            // ISO date string or ''
      completed: false,
      createdAt: Date.now(),
    };
  }

  /* =========================================================
     4. CRUD OPERATIONS
  ========================================================= */
  function addTask(title, note, priority, dueDate) {
    if (!title.trim()) return false;
    const task = createTask(title, note, priority, dueDate);
    state.tasks.unshift(task);
    saveToStorage();
    render();
    showToast('Task added!', 'success');
    return true;
  }

  function toggleTask(id) {
    const task = state.tasks.find(t => t.id === id);
    if (!task) return;
    task.completed = !task.completed;
    saveToStorage();
    render();
    showToast(task.completed ? 'Task completed ✓' : 'Task reopened', 'success');
  }

  function deleteTask(id, withUndo = true) {
    const idx = state.tasks.findIndex(t => t.id === id);
    if (idx === -1) return;
    const [removed] = state.tasks.splice(idx, 1);
    saveToStorage();
    render();
    if (withUndo) {
      undoBuffer = { task: removed, idx };
      showToast('Task deleted', 'error', true);
    }
  }

  function updateTask(id, title, note, priority, dueDate) {
    const task = state.tasks.find(t => t.id === id);
    if (!task) return;
    task.title = title.trim() || task.title;
    task.note = note.trim();
    task.priority = priority;
    task.dueDate = dueDate;
    saveToStorage();
    render();
    showToast('Task updated', 'success');
  }

  function undoDelete() {
    if (!undoBuffer) return;
    const { task, idx } = undoBuffer;
    state.tasks.splice(Math.min(idx, state.tasks.length), 0, task);
    undoBuffer = null;
    saveToStorage();
    render();
    showToast('Task restored!', 'success');
  }

  function clearCompleted() {
    const count = state.tasks.filter(t => t.completed).length;
    if (!count) return;
    state.tasks = state.tasks.filter(t => !t.completed);
    saveToStorage();
    render();
    showToast(`Cleared ${count} completed task${count > 1 ? 's' : ''}`, 'success');
  }

  /* =========================================================
     5. FILTERING, SEARCHING, SORTING
  ========================================================= */
  function getVisibleTasks() {
    let tasks = [...state.tasks];

    // Filter
    if (state.filter === 'active')    tasks = tasks.filter(t => !t.completed);
    if (state.filter === 'completed') tasks = tasks.filter(t => t.completed);

    // Search
    if (state.search.trim()) {
      const q = state.search.toLowerCase();
      tasks = tasks.filter(t =>
        t.title.toLowerCase().includes(q) ||
        t.note.toLowerCase().includes(q)
      );
    }

    // Sort
    const PRIORITY_ORDER = { high: 0, medium: 1, low: 2 };
    switch (state.sort) {
      case 'created-asc':  tasks.sort((a, b) => a.createdAt - b.createdAt); break;
      case 'created-desc': tasks.sort((a, b) => b.createdAt - a.createdAt); break;
      case 'priority':     tasks.sort((a, b) => PRIORITY_ORDER[a.priority] - PRIORITY_ORDER[b.priority]); break;
      case 'due':          tasks.sort((a, b) => {
        if (!a.dueDate && !b.dueDate) return 0;
        if (!a.dueDate) return 1;
        if (!b.dueDate) return -1;
        return a.dueDate.localeCompare(b.dueDate);
      }); break;
      case 'alpha':        tasks.sort((a, b) => a.title.localeCompare(b.title)); break;
    }

    return tasks;
  }

  /* =========================================================
     6. DUE DATE HELPERS
  ========================================================= */
  function formatDueDate(isoDate) {
    if (!isoDate) return null;
    const due = new Date(isoDate + 'T00:00:00');
    const today = new Date(); today.setHours(0,0,0,0);
    const diff = Math.round((due - today) / 86400000);
    if (diff < 0)  return { text: `${Math.abs(diff)}d overdue`, cls: 'overdue' };
    if (diff === 0) return { text: 'Due today', cls: 'today' };
    if (diff === 1) return { text: 'Due tomorrow', cls: '' };
    if (diff <= 7)  return { text: `Due in ${diff}d`, cls: '' };
    return { text: `Due ${due.toLocaleDateString('en-IN', { day:'numeric', month:'short' })}`, cls: '' };
  }

  /* =========================================================
     7. RENDER (DOM manipulation)
  ========================================================= */
  function render() {
    const list = document.getElementById('taskList');
    const emptyState = document.getElementById('emptyState');
    const emptyDesc = document.getElementById('emptyDesc');
    const visible = getVisibleTasks();

    // Stats
    const total = state.tasks.length;
    const done  = state.tasks.filter(t => t.completed).length;
    const active = total - done;
    const high  = state.tasks.filter(t => t.priority === 'high' && !t.completed).length;

    document.getElementById('statTotal').textContent = total;
    document.getElementById('statActive').textContent = active;
    document.getElementById('statDone').textContent = done;
    document.getElementById('statHigh').textContent = high;

    // Progress
    const pct = total === 0 ? 0 : Math.round((done / total) * 100);
    document.getElementById('progressFill').style.width = pct + '%';
    document.getElementById('progressPct').textContent = pct + '%';
    const bar = document.getElementById('progressBar');
    bar.setAttribute('aria-valuenow', pct);

    // Empty state
    if (visible.length === 0) {
      list.innerHTML = '';
      emptyState.classList.add('show');
      if (state.search.trim()) {
        emptyDesc.textContent = `No tasks match "${state.search}".`;
      } else if (state.filter === 'active') {
        emptyDesc.textContent = 'No active tasks — great job!';
      } else if (state.filter === 'completed') {
        emptyDesc.textContent = 'No completed tasks yet. Keep going!';
      } else {
        emptyDesc.textContent = 'Add your first task above to get started.';
      }
      return;
    }

    emptyState.classList.remove('show');

    // Diff render: only update changed cards
    const existingIds = new Set([...list.querySelectorAll('[data-id]')].map(el => el.dataset.id));
    const newIds = new Set(visible.map(t => t.id));

    // Remove cards no longer visible
    existingIds.forEach(id => {
      if (!newIds.has(id)) {
        const el = list.querySelector(`[data-id="${id}"]`);
        if (el) el.remove();
      }
    });

    // Insert / update cards in order
    visible.forEach((task, index) => {
      let el = list.querySelector(`[data-id="${task.id}"]`);
      if (!el) {
        el = buildTaskCard(task);
        list.appendChild(el);
      } else {
        syncTaskCard(el, task);
      }
      // Ensure correct DOM order
      if (list.children[index] !== el) {
        list.insertBefore(el, list.children[index] || null);
      }
    });
  }

  function buildTaskCard(task) {
    const el = document.createElement('div');
    el.className = `task-card priority-${task.priority}${task.completed ? ' completed' : ''}`;
    el.setAttribute('data-id', task.id);
    el.setAttribute('role', 'listitem');
    el.innerHTML = taskCardHTML(task);
    return el;
  }

  function syncTaskCard(el, task) {
    // Update classes
    el.className = `task-card priority-${task.priority}${task.completed ? ' completed' : ''}`;
    // Update inner HTML
    el.innerHTML = taskCardHTML(task);
  }

  function taskCardHTML(task) {
    const due = task.dueDate ? formatDueDate(task.dueDate) : null;
    const dueBadge = due
      ? `<span class="due-badge ${due.cls}" aria-label="Due: ${due.text}">📅 ${due.text}</span>`
      : '';
    const noteLine = task.note
      ? `<p class="task-note">${escapeHTML(task.note)}</p>`
      : '';

    return `
      <div class="task-checkbox-wrap">
        <input
          type="checkbox"
          class="task-checkbox"
          ${task.completed ? 'checked' : ''}
          aria-label="${task.completed ? 'Mark as active' : 'Mark as completed'}: ${escapeHTML(task.title)}"
          data-action="toggle"
        >
      </div>
      <div class="task-body">
        <div class="task-display">
          <div class="task-title-row">
            <span
              class="task-title"
              data-action="start-edit"
              title="Double-click to edit"
              tabindex="0"
              role="button"
              aria-label="Edit task: ${escapeHTML(task.title)}"
            >${escapeHTML(task.title)}</span>
          </div>
          ${noteLine}
          <div class="task-meta-row">
            <span class="priority-badge ${task.priority}">${task.priority}</span>
            ${dueBadge}
          </div>
        </div>
        <div class="task-edit-form" aria-label="Edit task form">
          <input type="text" class="edit-input" data-field="title" value="${escapeHTML(task.title)}" aria-label="Edit title" maxlength="100">
          <input type="text" class="edit-input" data-field="note" value="${escapeHTML(task.note)}" placeholder="Note (optional)" aria-label="Edit note" maxlength="200">
          <div style="display:flex;gap:var(--sp-3);flex-wrap:wrap">
            <select class="priority-select" data-field="priority" aria-label="Priority" style="flex:1">
              <option value="high" ${task.priority==='high'?'selected':''}>🔴 High</option>
              <option value="medium" ${task.priority==='medium'?'selected':''}>⚡ Medium</option>
              <option value="low" ${task.priority==='low'?'selected':''}>🟢 Low</option>
            </select>
            <input type="date" class="edit-input due-input" data-field="due" value="${task.dueDate}" aria-label="Due date" style="flex:1">
          </div>
          <div class="edit-actions">
            <button class="edit-cancel-btn" data-action="cancel-edit" aria-label="Cancel edit">Cancel</button>
            <button class="edit-save-btn" data-action="save-edit" aria-label="Save changes">Save changes</button>
          </div>
        </div>
      </div>
      <div class="task-actions" aria-label="Task actions">
        <button class="task-action-btn" data-action="start-edit" aria-label="Edit task">✏️</button>
        <button class="task-action-btn delete" data-action="delete" aria-label="Delete task">🗑️</button>
      </div>
    `;
  }

  function escapeHTML(str) {
    return String(str)
      .replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;')
      .replace(/"/g,'&quot;').replace(/'/g,'&#39;');
  }

  /* =========================================================
     8. DELEGATED EVENT LISTENERS
  ========================================================= */
  // All task interactions via event delegation on the list container
  document.getElementById('taskList').addEventListener('click', e => {
    const card = e.target.closest('[data-id]');
    if (!card) return;
    const id = card.dataset.id;
    const action = e.target.dataset.action || e.target.closest('[data-action]')?.dataset.action;

    if (!action) return;
    e.stopPropagation();

    switch (action) {
      case 'toggle':
        toggleTask(id);
        break;
      case 'delete':
        animateRemove(card, () => deleteTask(id));
        break;
      case 'start-edit':
        startEdit(card);
        break;
      case 'cancel-edit':
        cancelEdit(card);
        break;
      case 'save-edit':
        saveEdit(card, id);
        break;
    }
  });

  // Double-click on title also starts edit
  document.getElementById('taskList').addEventListener('dblclick', e => {
    const titleEl = e.target.closest('.task-title');
    if (titleEl) {
      const card = titleEl.closest('[data-id]');
      if (card) startEdit(card);
    }
  });

  // Keyboard: Enter/Space on title → start edit; Escape → cancel edit
  document.getElementById('taskList').addEventListener('keydown', e => {
    const card = e.target.closest('[data-id]');
    if (!card) return;
    const id = card.dataset.id;

    if ((e.key === 'Enter' || e.key === ' ') && e.target.classList.contains('task-title')) {
      e.preventDefault();
      startEdit(card);
    }
    if (e.key === 'Escape' && card.classList.contains('editing')) {
      cancelEdit(card);
    }
    if (e.key === 'Enter' && e.target.classList.contains('edit-input')) {
      saveEdit(card, id);
    }
  });

  /* =========================================================
     9. INLINE EDIT LOGIC
  ========================================================= */
  function startEdit(card) {
    // Cancel any other open edits first
    document.querySelectorAll('.task-card.editing').forEach(c => {
      if (c !== card) cancelEdit(c);
    });
    card.classList.add('editing');
    const titleInput = card.querySelector('[data-field="title"]');
    if (titleInput) { titleInput.focus(); titleInput.select(); }
  }

  function cancelEdit(card) {
    card.classList.remove('editing');
    // Re-render the card to its saved state
    const id = card.dataset.id;
    const task = state.tasks.find(t => t.id === id);
    if (task) syncTaskCard(card, task);
  }

  function saveEdit(card, id) {
    const titleInput = card.querySelector('[data-field="title"]');
    const noteInput  = card.querySelector('[data-field="note"]');
    const priSelect  = card.querySelector('[data-field="priority"]');
    const dueInput   = card.querySelector('[data-field="due"]');

    const newTitle = titleInput?.value.trim();
    if (!newTitle) {
      titleInput?.classList.add('error');
      titleInput?.focus();
      return;
    }

    updateTask(id, newTitle, noteInput?.value || '', priSelect?.value || 'medium', dueInput?.value || '');
  }

  /* =========================================================
     10. ADD TASK FORM
  ========================================================= */
  const titleInput   = document.getElementById('taskTitleInput');
  const noteInput    = document.getElementById('taskNoteInput');
  const prioritySel  = document.getElementById('prioritySelect');
  const dueDateInput = document.getElementById('dueDateInput');
  const addBtn       = document.getElementById('addTaskBtn');
  const charCount    = document.getElementById('titleCharCount');
  const addError     = document.getElementById('addError');

  titleInput.addEventListener('input', () => {
    const len = titleInput.value.length;
    charCount.textContent = `${len} / 100`;
    charCount.classList.toggle('warn', len > 85);
    addError.classList.remove('show');
    titleInput.removeAttribute('aria-invalid');
  });

  function handleAddTask() {
    const title = titleInput.value.trim();
    if (!title) {
      addError.classList.add('show');
      titleInput.setAttribute('aria-invalid', 'true');
      titleInput.focus();
      return;
    }
    const success = addTask(title, noteInput.value, prioritySel.value, dueDateInput.value);
    if (success) {
      titleInput.value = '';
      noteInput.value = '';
      dueDateInput.value = '';
      prioritySel.value = 'medium';
      charCount.textContent = '0 / 100';
      addError.classList.remove('show');
      titleInput.focus();
    }
  }

  addBtn.addEventListener('click', handleAddTask);
  titleInput.addEventListener('keydown', e => {
    if (e.key === 'Enter') handleAddTask();
  });

  /* =========================================================
     11. FILTER TABS
  ========================================================= */
  document.querySelectorAll('.filter-tab').forEach(tab => {
    tab.addEventListener('click', () => {
      document.querySelectorAll('.filter-tab').forEach(t => {
        t.classList.remove('active');
        t.setAttribute('aria-selected', 'false');
      });
      tab.classList.add('active');
      tab.setAttribute('aria-selected', 'true');
      state.filter = tab.dataset.filter;
      render();
    });
  });

  /* =========================================================
     12. SORT
  ========================================================= */
  document.getElementById('sortSelect').addEventListener('change', e => {
    state.sort = e.target.value;
    render();
  });

  /* =========================================================
     13. SEARCH
  ========================================================= */
  document.getElementById('searchInput').addEventListener('input', e => {
    state.search = e.target.value;
    render();
  });

  /* =========================================================
     14. CLEAR COMPLETED
  ========================================================= */
  document.getElementById('clearCompletedBtn').addEventListener('click', clearCompleted);

  /* =========================================================
     15. ANIMATE REMOVE
  ========================================================= */
  function animateRemove(card, callback) {
    card.classList.add('removing');
    card.addEventListener('animationend', () => callback(), { once: true });
    // Fallback
    setTimeout(callback, 400);
  }

  /* =========================================================
     16. TOAST NOTIFICATIONS
  ========================================================= */
  function showToast(message, type = 'success', withUndo = false) {
    const container = document.getElementById('toastContainer');
    const toast = document.createElement('div');
    toast.className = `toast ${type}`;
    toast.innerHTML = `
      <span class="toast-icon" aria-hidden="true">${type === 'success' ? '✓' : '✕'}</span>
      <span>${escapeHTML(message)}</span>
      ${withUndo ? '<button class="toast-undo" aria-label="Undo last action">Undo</button>' : ''}
    `;
    container.appendChild(toast);

    if (withUndo) {
      toast.querySelector('.toast-undo').addEventListener('click', () => {
        undoDelete();
        removeToast(toast);
      });
    }

    setTimeout(() => removeToast(toast), 4000);
  }

  function removeToast(toast) {
    toast.classList.add('fade-out');
    toast.addEventListener('animationend', () => toast.remove(), { once: true });
  }

  /* =========================================================
     17. DARK MODE
  ========================================================= */
  const html = document.documentElement;
  const themeToggle = document.getElementById('themeToggle');
  const stored = localStorage.getItem('theme');
  const prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
  html.setAttribute('data-theme', stored || (prefersDark ? 'dark' : 'light'));

  themeToggle.addEventListener('click', () => {
    const next = html.getAttribute('data-theme') === 'dark' ? 'light' : 'dark';
    html.setAttribute('data-theme', next);
    localStorage.setItem('theme', next);
  });

  /* =========================================================
     18. SEED DATA (only on first load if storage is empty)
  ========================================================= */
  function seedIfEmpty() {
    if (state.tasks.length > 0) return;
    const today = new Date();
    const fmt = d => d.toISOString().split('T')[0];
    const tomorrow = new Date(today); tomorrow.setDate(today.getDate() + 1);
    const nextWeek = new Date(today); nextWeek.setDate(today.getDate() + 7);
    const yesterday = new Date(today); yesterday.setDate(today.getDate() - 1);

    state.tasks = [
      { id: crypto.randomUUID?.() || '1', title: 'Review accessibility audit for AccessAudit', note: 'Focus on WCAG 2.2 success criteria 2.5.3', priority: 'high', dueDate: fmt(tomorrow), completed: false, createdAt: Date.now() - 5000 },
      { id: crypto.randomUUID?.() || '2', title: 'Push FocusFlow v1.2 to GitHub', note: 'Remember to update the README', priority: 'medium', dueDate: fmt(nextWeek), completed: false, createdAt: Date.now() - 4000 },
      { id: crypto.randomUUID?.() || '3', title: 'Export PaletteCheck colour tokens as CSS', note: '', priority: 'low', dueDate: '', completed: true, createdAt: Date.now() - 3000 },
      { id: crypto.randomUUID?.() || '4', title: 'Update portfolio hero section copy', note: 'Make it more concise', priority: 'medium', dueDate: fmt(yesterday), completed: false, createdAt: Date.now() - 2000 },
      { id: crypto.randomUUID?.() || '5', title: 'Read MDN article on CSS container queries', note: '', priority: 'low', dueDate: '', completed: true, createdAt: Date.now() - 1000 },
    ];
    saveToStorage();
  }

  /* =========================================================
     19. INITIALISE
  ========================================================= */
  loadFromStorage();
  seedIfEmpty();
  render();

  </script>
</body>
</html>
