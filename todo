    @keyframes toastIn{from{opacity:0;transform:translateX(40px)}to{opacity:1;transform:none}}
    .toast.fade-out{animation:toastOut .3s var(--ease) forwards}
    @keyframes toastOut{to{opacity:0;transform:translateX(40px)}}
    .toast-icon{font-size:1rem}
    .toast.success .toast-icon{color:var(--success)}
    .toast.error .toast-icon{color:var(--danger)}
    .toast-undo{
      margin-left:auto;font-size:.78rem;font-weight:700;
      color:var(--accent);background:none;border:none;cursor:pointer;
      padding:0;text-decoration:underline
    }

    /* ============================
       FOOTER
    ============================ */
    footer{
      border-top:1px solid var(--border);padding-block:var(--sp-6);
      margin-top:var(--sp-8)
    }
    .footer-inner{
      max-width:var(--max-w);margin-inline:auto;padding-inline:var(--sp-6);
      display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:var(--sp-4)
    }
    footer p{font-size:.8rem;color:var(--text-muted)}
    .kbd{
      display:inline-block;font-size:.7rem;padding:1px 5px;
      border:1px solid var(--border);border-bottom-width:2px;
      border-radius:4px;background:var(--bg-surface-2);
      color:var(--text-muted);font-family:monospace
    }

    /* ============================
       FOCUS
    ============================ */
    :focus-visible{outline:2px solid var(--accent);outline-offset:3px}

    /* ============================
       RESPONSIVE
    ============================ */
    @media(max-width:480px){
      .controls-bar{flex-direction:column;align-items:stretch}
      .filter-tabs{justify-content:center}
      .add-task-row{flex-direction:column}
      .task-actions{opacity:1}
    }
  </style>
</head>
<body>

