          class="task-input" id="taskTitleInput" type="text"
          placeholder="What needs to be done?" maxlength="100"
          aria-label="Task title" aria-describedby="titleCharCount addError"
          autocomplete="off" spellcheck="true"
        >
        <div class="input-row">
