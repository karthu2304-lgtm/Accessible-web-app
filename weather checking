/* ─────────────────────────────────────────────────────────────
   2. STATE
───────────────────────────────────────────────────────────── */
let currentUnit = 'C';
let lastWeatherData = null;

/* ─────────────────────────────────────────────────────────────
   3. WEATHER ICON MAP (condition → emoji)
───────────────────────────────────────────────────────────── */
const ICONS = {
  'clear sky': '☀️', 'few clouds': '🌤️', 'scattered clouds': '⛅',
  'broken clouds': '🌥️', 'overcast clouds': '☁️',
  'light rain': '🌦️', 'moderate rain': '🌧️', 'heavy rain': '⛈️',
  'light snow': '🌨️', 'snow': '❄️',
  'thunderstorm': '⛈️', 'mist': '🌫️', 'fog': '🌫️',
  'haze': '🌫️', 'smoke': '🌫️', 'drizzle': '🌦️',
};
function getIcon(desc = '') {
  const key = Object.keys(ICONS).find(k => desc.toLowerCase().includes(k));
  return key ? ICONS[key] : '🌤️';
}

/* ─────────────────────────────────────────────────────────────
   4. SKY THEME — changes the gradient background by condition
───────────────────────────────────────────────────────────── */
const SKY_THEMES = {
  clear:   { a:'rgba(255,180,50,.18)',  b:'rgba(255,120,40,.10)', c:'#100a02', glow:'rgba(255,160,60,.2)' },
  cloudy:  { a:'rgba(80,100,140,.20)',  b:'rgba(60,80,120,.12)',  c:'#08090d', glow:'rgba(100,140,200,.15)' },
  rain:    { a:'rgba(40,70,140,.22)',   b:'rgba(20,50,120,.14)',  c:'#060810', glow:'rgba(60,100,200,.15)' },
  snow:    { a:'rgba(180,200,240,.18)', b:'rgba(140,170,220,.10)',c:'#0a0c12', glow:'rgba(180,210,255,.2)' },
  thunder: { a:'rgba(80,40,160,.22)',   b:'rgba(60,20,120,.14)',  c:'#06040d', glow:'rgba(120,80,220,.2)' },
  mist:    { a:'rgba(120,130,150,.18)', b:'rgba(90,100,120,.10)', c:'#080a0d', glow:'rgba(140,160,190,.1)' },
};
function applySkyTheme(desc = '') {
  let t = SKY_THEMES.cloudy;
  if (/clear/i.test(desc)) t = SKY_THEMES.clear;
  else if (/rain|drizzle|shower/i.test(desc)) t = SKY_THEMES.rain;
  else if (/snow/i.test(desc)) t = SKY_THEMES.snow;
  else if (/thunder/i.test(desc)) t = SKY_THEMES.thunder;
  else if (/mist|fog|haze|smoke/i.test(desc)) t = SKY_THEMES.mist;
  const root = document.documentElement;
  root.style.setProperty('--sky-a', t.a);
  root.style.setProperty('--sky-b', t.b);
  root.style.setProperty('--sky-c', t.c);
  root.style.setProperty('--glow', t.glow);
}

/* ─────────────────────────────────────────────────────────────
   5. TEMPERATURE CONVERSION
───────────────────────────────────────────────────────────── */
const toF = c => Math.round(c * 9 / 5 + 32);
const fmt  = (c, unit) => unit === 'F' ? toF(c) : Math.round(c);

/* ─────────────────────────────────────────────────────────────
   6. REQUEST LOG (educational UI)
───────────────────────────────────────────────────────────── */
function logStep(msg, type = 'pending') {
  const log = document.getElementById('requestLog');
  if (log.querySelector('div[style]')) log.innerHTML = ''; // clear placeholder
  const entry = document.createElement('div');
  entry.className = `log-entry ${type}`;
  entry.innerHTML = `<span class="log-dot"></span><span>${msg}</span>`;
  log.appendChild(entry);
  log.scrollTop = log.scrollHeight;
}
function logResolve(idx, type = 'success') {
  const entries = document.querySelectorAll('.log-entry');
  if (entries[idx]) entries[idx].className = `log-entry ${type}`;
}

/* ─────────────────────────────────────────────────────────────
