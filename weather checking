/* ─────────────────────────────────────────────────────────────
   8. COMPASS DIRECTION
───────────────────────────────────────────────────────────── */
function windDir(deg) {
  const dirs = ['N','NE','E','SE','S','SW','W','NW'];
  return dirs[Math.round(deg / 45) % 8];
}

/* ─────────────────────────────────────────────────────────────
   9. ASYNC FETCH (uses Anthropic API to simulate a real weather
      API response — demonstrates the same async/await pattern)
───────────────────────────────────────────────────────────── */

/**
 * fetchWeatherData — the core async function students should study.
 *
 * In a real deployment you'd call:
 *   https://api.openweathermap.org/data/2.5/weather?q={city}&appid={key}
 *
 * Here we call the Anthropic API with a strict JSON prompt so the
 * response structure is identical — the async/await + error-handling
 * pattern is exactly the same either way.
 */
async function fetchWeatherData(city) {
  const LOG = [];

  // Step 1 — validate input (sync guard before async work)
  logStep(`[1/5] Validating input: "${city}"`, 'pending'); LOG.push(0);
  if (!city || city.trim().length < 2) throw new Error('Please enter a city name (at least 2 characters).');
  await sleep(200);
  logResolve(0, 'success');

  // Step 2 — build request
  logStep('[2/5] Building API request (URL + headers)…', 'pending'); LOG.push(1);
  await sleep(300);
  logResolve(1, 'success');

  // Step 3 — fire the fetch
  logStep('[3/5] await fetch() → sending HTTP GET…', 'pending'); LOG.push(2);

  const prompt = `You are a weather API. Return ONLY a valid JSON object (no prose, no markdown) for the city "${city}".

If the city doesn't exist or is clearly nonsense, return: {"error": "City not found: ${city}"}

Otherwise return this exact structure with realistic, plausible values:
{
  "city": "<proper city name>",
  "country": "<2-letter ISO country code>",
  "lat": <number>,
  "lon": <number>,
  "timezone_offset": <integer seconds from UTC>,
  "description": "<one of: clear sky, few clouds, scattered clouds, broken clouds, overcast clouds, light rain, moderate rain, heavy rain, thunderstorm, light snow, mist, haze>",
  "temp_c": <integer celsius>,
  "feels_like_c": <integer celsius>,
  "temp_min_c": <integer celsius>,
  "temp_max_c": <integer celsius>,
  "humidity": <integer 0-100>,
  "pressure": <integer hPa, typically 980-1030>,
  "wind_speed": <number m/s>,
  "wind_deg": <integer 0-360>,
  "wind_gust": <number m/s or null>,
  "visibility": <integer metres, 1000-10000>,
  "clouds": <integer 0-100>,
  "uv_index": <number 0-11>,
  "dew_point_c": <integer celsius>,
  "aqi": <integer 1-5>,
  "aqi_label": "<one of: Good, Fair, Moderate, Poor, Very Poor>",
  "sunrise_offset": <integer minutes after midnight local time, 300-420>,
  "sunset_offset": <integer minutes after midnight local time, 1050-1200>,
  "forecast": [
    { "day": "Today", "icon_desc": "<weather desc>", "high_c": <int>, "low_c": <int>, "rain_pct": <int 0-100> },
    { "day": "Mon",   "icon_desc": "<weather desc>", "high_c": <int>, "low_c": <int>, "rain_pct": <int 0-100> },
    { "day": "Tue",   "icon_desc": "<weather desc>", "high_c": <int>, "low_c": <int>, "rain_pct": <int 0-100> },
    { "day": "Wed",   "icon_desc": "<weather desc>", "high_c": <int>, "low_c": <int>, "rain_pct": <int 0-100> },
    { "day": "Thu",   "icon_desc": "<weather desc>", "high_c": <int>, "low_c": <int>, "rain_pct": <int 0-100> },
    { "day": "Fri",   "icon_desc": "<weather desc>", "high_c": <int>, "low_c": <int>, "rain_pct": <int 0-100> },
    { "day": "Sat",   "icon_desc": "<weather desc>", "high_c": <int>, "low_c": <int>, "rain_pct": <int 0-100> }
  ]
}`;

  let response;
  try {
    response = await fetch('https://api.anthropic.com/v1/messages', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({
        model: 'claude-sonnet-4-20250514',
        max_tokens: 1000,
        messages: [{ role: 'user', content: prompt }],
      }),
    });
  } catch (networkErr) {
    logResolve(2, 'error');
    throw new Error('Network error — check your internet connection.');
  }
  logResolve(2, 'success');

  // Step 4 — check HTTP status (important! fetch() doesn't throw on 4xx/5xx)
  logStep(`[4/5] response.ok check — HTTP ${response.status}…`, 'pending');
  await sleep(200);
  if (!response.ok) {
    logResolve(3, 'error');
    if (response.status === 401) throw new Error('Unauthorised — API key rejected (HTTP 401).');
    if (response.status === 429) throw new Error('Rate limited — too many requests (HTTP 429).');
    throw new Error(`Server error: HTTP ${response.status}`);
  }
  logResolve(3, 'success');

  // Step 5 — parse JSON (also async — response.json() returns a Promise)
  logStep('[5/5] await response.json() → parsing nested JSON…', 'pending');
  const apiData = await response.json();

  // Extract text from Anthropic response shape
  const raw = apiData?.content?.[0]?.text || '';
  let weather;
  try {
    // Strip any accidental markdown fences
    const clean = raw.replace(/```json|```/g, '').trim();
    weather = JSON.parse(clean);
  } catch {
    logResolve(4, 'error');
    throw new Error('Failed to parse JSON response from API.');
  }

  if (weather.error) {
    logResolve(4, 'error');
    throw new Error(weather.error);
  }

  logResolve(4, 'success');
  return weather;
}

const sleep = ms => new Promise(r => setTimeout(r, ms));

/* ─────────────────────────────────────────────────────────────
   10. RENDER DASHBOARD
───────────────────────────────────────────────────────────── */
function renderDashboard(w) {
  lastWeatherData = w;
  const u = currentUnit;
  const dash = document.getElementById('weatherDashboard');

  applySkyTheme(w.description);

  // ── Hero ──────────────────────────────────────────────
  document.getElementById('cityName').textContent = w.city;
  document.getElementById('cityCountry').textContent = `${w.country} · ${w.lat?.toFixed(2)}°N, ${w.lon?.toFixed(2)}°E`;

  // Local time from timezone_offset
  const nowUtc = Date.now() + (new Date().getTimezoneOffset() * 60000);
  const local = new Date(nowUtc + w.timezone_offset * 1000);
  const timeStr = local.toLocaleTimeString('en-IN', { hour: '2-digit', minute: '2-digit', hour12: true });
  const dateStr = local.toLocaleDateString('en-IN', { weekday: 'long', day: 'numeric', month: 'long' });
  document.getElementById('cityTime').textContent = `${dateStr} · ${timeStr} local`;

  document.getElementById('weatherIconHero').textContent = getIcon(w.description);
  document.getElementById('tempMain').textContent = fmt(w.temp_c, u);
  document.getElementById('tempUnitLabel').textContent = `°${u}`;
  document.getElementById('tempFeels').textContent =
    `Feels like ${fmt(w.feels_like_c, u)}°${u}  ·  H: ${fmt(w.temp_max_c, u)}°  L: ${fmt(w.temp_min_c, u)}°`;
  document.getElementById('weatherDesc').textContent = w.description;

  // Hero quick stats
  document.getElementById('heroStats').innerHTML = [
    { icon:'💧', val:`${w.humidity}%`,             key:'Humidity' },
    { icon:'💨', val:`${w.wind_speed} m/s`,        key:`Wind ${windDir(w.wind_deg)}` },
    { icon:'👁️',  val:`${(w.visibility/1000).toFixed(1)} km`, key:'Visibility' },
    { icon:'🌡️', val:`${w.pressure} hPa`,          key:'Pressure' },
    { icon:'☁️', val:`${w.clouds}%`,               key:'Cloud cover' },
  ].map(s => `
    <div class="hero-stat">
      <div class="stat-icon">${s.icon}</div>
      <div class="stat-val">${s.val}</div>
      <div class="stat-key">${s.key}</div>
    </div>
  `).join('');

  // ── Metrics grid ──────────────────────────────────────
  const metrics = [
    {
      icon:'🌡️', label:'Real Feel',
      val:`${fmt(w.feels_like_c, u)}°${u}`,
      sub:`Actual: ${fmt(w.temp_c, u)}°${u}`,
      bar: null
    },
    {
      icon:'💧', label:'Humidity',
      val:`${w.humidity}%`,
      sub: w.humidity > 70 ? 'High — feels muggy' : w.humidity > 40 ? 'Comfortable' : 'Low — dry air',
      bar: w.humidity
    },
    {
      icon:'💨', label:'Wind Speed',
      val:`${w.wind_speed} m/s`,
      sub:`${windDir(w.wind_deg)} · Gusts ${w.wind_gust ? w.wind_gust + ' m/s' : 'none'}`,
      bar: Math.min(w.wind_speed / 30 * 100, 100)
    },
    {
      icon:'🌡️', label:'Pressure',
      val:`${w.pressure} hPa`,
      sub: w.pressure > 1013 ? 'High pressure — fair weather' : 'Low pressure — possible rain',
      bar: Math.min((w.pressure - 970) / 60 * 100, 100)
    },
    {
      icon:'👁️', label:'Visibility',
      val:`${(w.visibility/1000).toFixed(1)} km`,
      sub: w.visibility >= 8000 ? 'Clear visibility' : w.visibility >= 4000 ? 'Moderate' : 'Poor visibility',
      bar: w.visibility / 10000 * 100
    },
    {
      icon:'☀️', label:'UV Index',
      val: w.uv_index?.toFixed(1) ?? '—',
      sub: uvLabel(w.uv_index),
      bar: Math.min(w.uv_index / 11 * 100, 100)
    },
    {
      icon:'🌡️', label:'Dew Point',
      val:`${fmt(w.dew_point_c, u)}°${u}`,
      sub: w.dew_point_c > 20 ? 'Uncomfortable' : w.dew_point_c > 13 ? 'Somewhat humid' : 'Dry & comfortable',
      bar: null
    },
    {
      icon:'🍃', label:'Air Quality',
      val: w.aqi_label,
      sub:`AQI index: ${w.aqi} / 5`,
      bar: (6 - w.aqi) / 5 * 100
    },
  ];

  document.getElementById('metricsGrid').innerHTML = metrics.map((m, i) => `
    <div class="metric-card" style="animation-delay:${i * .06}s">
      <div class="metric-icon">${m.icon}</div>
      <div class="metric-label">${m.label}</div>
      <div class="metric-val">${m.val}</div>
      <div class="metric-sub">${m.sub}</div>
      ${m.bar !== null ? `
        <div class="metric-bar-track">
          <div class="metric-bar-fill" style="width:0%" data-target="${Math.round(m.bar)}%"></div>
        </div>` : ''}
    </div>
  `).join('');

  // Animate bars after paint
  requestAnimationFrame(() => {
    document.querySelectorAll('.metric-bar-fill').forEach(el => {
      el.style.width = el.dataset.target;
    });
  });

  // ── Forecast ─────────────────────────────────────────
  document.getElementById('forecastGrid').innerHTML = (w.forecast || []).map((f, i) => `
    <div class="forecast-card${i === 0 ? ' today' : ''}" style="animation-delay:${i * .07}s">
      <div class="fc-day">${f.day}</div>
      <div class="fc-icon">${getIcon(f.icon_desc)}</div>
      <div class="fc-high">${fmt(f.high_c, u)}°</div>
      <div class="fc-low">${fmt(f.low_c, u)}°</div>
      ${f.rain_pct > 0 ? `<div class="fc-rain">💧 ${f.rain_pct}%</div>` : ''}
    </div>
  `).join('');

  // Show dashboard
  dash.style.display = 'block';
  document.getElementById('logCity').textContent = w.city;
}

function uvLabel(uv) {
  if (!uv && uv !== 0) return '—';
  if (uv <= 2) return 'Low — no protection needed';
  if (uv <= 5) return 'Moderate — wear sunscreen';
  if (uv <= 7) return 'High — limit sun exposure';
  if (uv <= 10) return 'Very High — protection essential';
  return 'Extreme — avoid direct sunlight';
}

/* ─────────────────────────────────────────────────────────────
   11. RE-RENDER ON UNIT TOGGLE (no extra fetch)
───────────────────────────────────────────────────────────── */
document.querySelectorAll('.unit-btn').forEach(btn => {
  btn.addEventListener('click', () => {
    document.querySelectorAll('.unit-btn').forEach(b => {
      b.classList.remove('active');
      b.setAttribute('aria-pressed', 'false');
    });
    btn.classList.add('active');
    btn.setAttribute('aria-pressed', 'true');
    currentUnit = btn.dataset.unit;
    if (lastWeatherData) renderDashboard(lastWeatherData);
  });
});

/* ─────────────────────────────────────────────────────────────
   12. MAIN SEARCH HANDLER — the async/await controller
───────────────────────────────────────────────────────────── */
async function handleSearch() {
  const city = document.getElementById('cityInput').value.trim();
  if (!city) {
    showError('Please enter a city name to search.');
    return;
  }

  showLoading();
  document.getElementById('requestLog').innerHTML = ''; // reset log
  document.getElementById('logCity').textContent = city;

  try {
    // ↓ async/await: pause here until fetchWeatherData resolves or rejects
    const weatherData = await fetchWeatherData(city);

    // ↓ runs only if the above succeeded — render parsed JSON to DOM
    renderDashboard(weatherData);
    hideStatus();

  } catch (err) {
    // ↓ centralised error handling — surfaces any error (network, HTTP, parse)
    showError(err.message);
    document.getElementById('weatherDashboard').style.display = 'none';

  } finally {
    // ↓ always runs — cleanup regardless of success or failure
    hideLoading();
  }
}

// Wire up search button
document.getElementById('searchBtn').addEventListener('click', handleSearch);

// Enter key in input
document.getElementById('cityInput').addEventListener('keydown', e => {
  if (e.key === 'Enter') handleSearch();
});

// Quick city pills
document.querySelectorAll('.quick-pill').forEach(pill => {
  const activate = () => {
    document.getElementById('cityInput').value = pill.dataset.city;
    handleSearch();
  };
  pill.addEventListener('click', activate);
  pill.addEventListener('keydown', e => { if (e.key === 'Enter' || e.key === ' ') { e.preventDefault(); activate(); } });
});

/* ─────────────────────────────────────────────────────────────
   13. AUTO-LOAD Chennai on first visit
───────────────────────────────────────────────────────────── */
window.addEventListener('load', () => {
  document.getElementById('cityInput').value = 'Chennai';
  handleSearch();
});
</script>
