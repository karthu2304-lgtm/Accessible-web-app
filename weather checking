<!DOCTYPE html>
<html lang="en" data-theme="dark">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>SkyWatch · Karthika</title>
  <meta name="description" content="Real-time weather dashboard demonstrating async/await, Fetch API, and dynamic JSON rendering.">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;600;700;800&family=DM+Sans:ital,wght@0,300;0,400;0,500;1,400&display=swap" rel="stylesheet">

  <style>
    /* ============================================================
       DESIGN TOKENS — Karthika portfolio palette extended for dark weather theme
    ============================================================ */
    :root {
      --bg-page: #0a0d14;
      --bg-surface: #111520;
      --bg-surface-2: #171c2e;
      --bg-surface-3: #1e2438;
      --text-primary: #eef0f8;
      --text-secondary: #9aa3c2;
      --text-muted: #5a6285;
      --accent: #e8784a;
      --accent-dark: #b04e1e;
      --accent-light: #3a2010;
      --border: #1e2438;
      --border-strong: #2e3558;
      --shadow-card: 0 4px 24px rgba(0,0,0,0.5);
      --shadow-hover: 0 12px 48px rgba(0,0,0,0.7);
      --font-display: 'Syne', sans-serif;
      --font-body: 'DM Sans', sans-serif;
      --r-sm: 6px; --r-md: 12px; --r-lg: 20px; --r-xl: 32px;
      --ease: cubic-bezier(.4,0,.2,1); --dur: .22s;
      --max-w: 1100px;

      /* Weather gradient themes — set by JS */
      --sky-a: #0a0d14;
      --sky-b: #111520;
      --sky-c: #171c2e;
      --glow: rgba(232,120,74,0.15);
    }

    /* ============================================================
       RESET
    ============================================================ */
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    html { font-size: 16px; scroll-behavior: smooth; }
    body {
      font-family: var(--font-body);
      background: var(--bg-page);
      color: var(--text-primary);
      min-height: 100vh;
      overflow-x: hidden;
      transition: background 1.2s var(--ease);
    }
    a { color: inherit; text-decoration: none; }
    button { font-family: var(--font-body); }

    /* ============================================================
       ANIMATED SKY BACKGROUND
    ============================================================ */
    .sky-bg {
      position: fixed; inset: 0; z-index: 0; pointer-events: none;
      background: radial-gradient(ellipse 80% 60% at 60% 20%, var(--sky-a) 0%, transparent 70%),
                  radial-gradient(ellipse 60% 80% at 20% 80%, var(--sky-b) 0%, transparent 70%),
                  linear-gradient(180deg, var(--sky-c) 0%, var(--bg-page) 100%);
      transition: background 2s var(--ease);
    }
    .sky-bg::after {
      content: '';
      position: absolute; inset: 0;
      background: url("data:image/svg+xml,%3Csvg width='200' height='200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.65' numOctaves='3' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='200' height='200' filter='url(%23n)' opacity='0.04'/%3E%3C/svg%3E");
      opacity: .4;
    }

    /* Stars */
    .stars { position: fixed; inset: 0; z-index: 0; pointer-events: none; overflow: hidden; }
    .star {
      position: absolute; background: #fff; border-radius: 50%;
      animation: twinkle var(--d,3s) var(--delay,0s) infinite alternate ease-in-out;
    }
    @keyframes twinkle { from { opacity: var(--lo,.2); } to { opacity: var(--hi,.9); } }

    /* ============================================================
       LAYOUT
    ============================================================ */
    .app-wrap {
      position: relative; z-index: 1;
      max-width: var(--max-w);
      margin-inline: auto;
      padding: 2rem 1.5rem 4rem;
      min-height: 100vh;
    }

    /* ============================================================
       HEADER
    ============================================================ */
    .site-header {
      display: flex; align-items: center; justify-content: space-between;
      gap: 1rem; margin-bottom: 2.5rem; flex-wrap: wrap;
    }
    .logo {
      font-family: var(--font-display); font-size: 1.1rem; font-weight: 800;
      letter-spacing: -.02em; color: var(--text-primary);
      display: flex; align-items: center; gap: .5rem;
    }
    .logo-dot { width: 8px; height: 8px; border-radius: 50%; background: var(--accent); flex-shrink: 0; }
    .header-right { display: flex; align-items: center; gap: .75rem; }
    .unit-toggle {
      display: flex; gap: 2px;
      background: var(--bg-surface-2); border: 1px solid var(--border-strong);
      border-radius: var(--r-md); padding: 3px;
    }
    .unit-btn {
      padding: .3rem .75rem; font-size: .78rem; font-weight: 700;
      border: none; border-radius: calc(var(--r-md) - 3px);
      background: transparent; color: var(--text-muted); cursor: pointer;
      transition: background var(--dur), color var(--dur);
    }
    .unit-btn.active { background: var(--accent); color: #fff; }
    .back-link {
      font-size: .8rem; color: var(--text-muted); display: flex; align-items: center; gap: 4px;
      transition: color var(--dur);
    }
    .back-link:hover { color: var(--accent); }

    /* ============================================================
       PAGE TITLE
    ============================================================ */
    .page-eyebrow {
      display: inline-flex; align-items: center; gap: .5rem;
      font-size: .7rem; font-weight: 700; letter-spacing: .12em; text-transform: uppercase;
      color: var(--accent); background: var(--accent-light);
      padding: .2rem .75rem; border-radius: 99px; margin-bottom: 1rem;
      border: 1px solid rgba(232,120,74,.2);
    }
    .eyebrow-dot { width: 6px; height: 6px; border-radius: 50%; background: var(--accent); animation: pulse 2s infinite; }
    @keyframes pulse { 0%,100%{opacity:1;transform:scale(1)} 50%{opacity:.4;transform:scale(.6)} }
    .page-title {
      font-family: var(--font-display); font-size: clamp(2rem, 5vw, 3.2rem);
      font-weight: 800; letter-spacing: -.03em; line-height: 1.1;
      color: var(--text-primary); margin-bottom: .5rem;
    }
    .page-title .accent { color: var(--accent); }
    .page-subtitle { font-size: .95rem; color: var(--text-secondary); margin-bottom: 2.5rem; max-width: 60ch; }

    /* ============================================================
       SEARCH BAR
    ============================================================ */
    .search-card {
      background: var(--bg-surface);
      border: 1px solid var(--border-strong);
      border-radius: var(--r-xl);
      padding: 1.25rem 1.5rem;
      box-shadow: var(--shadow-card);
      margin-bottom: 2rem;
      display: flex; gap: 1rem; align-items: center; flex-wrap: wrap;
    }
    .search-input-wrap { position: relative; flex: 1; min-width: 200px; }
    .search-icon { position: absolute; left: 1rem; top: 50%; transform: translateY(-50%); color: var(--text-muted); font-size: 1rem; pointer-events: none; }
    .search-input {
      width: 100%; padding: .75rem 1rem .75rem 2.75rem;
      font-size: .95rem; font-family: var(--font-body);
      background: var(--bg-surface-2); border: 1.5px solid var(--border-strong);
      border-radius: var(--r-lg); color: var(--text-primary);
      transition: border-color var(--dur), box-shadow var(--dur);
    }
    .search-input:focus { outline: none; border-color: var(--accent); box-shadow: 0 0 0 3px rgba(232,120,74,.15); }
    .search-input::placeholder { color: var(--text-muted); }
    .search-btn {
      padding: .75rem 1.75rem; font-size: .9rem; font-weight: 700;
      background: var(--accent); color: #fff; border: none;
      border-radius: var(--r-lg); cursor: pointer;
      transition: background var(--dur), transform var(--dur), box-shadow var(--dur);
      white-space: nowrap; display: flex; align-items: center; gap: .5rem;
      flex-shrink: 0;
    }
    .search-btn:hover { background: var(--accent-dark); box-shadow: 0 4px 20px rgba(232,120,74,.4); }
    .search-btn:active { transform: scale(.97); }
    .search-btn:disabled { opacity: .5; cursor: not-allowed; transform: none; }
    .search-btn:focus-visible { outline: 2px solid var(--accent); outline-offset: 3px; }

    /* Quick cities */
    .quick-cities { display: flex; gap: .5rem; flex-wrap: wrap; margin-top: .75rem; width: 100%; }
    .quick-pill {
      font-size: .75rem; font-weight: 600; padding: .25rem .75rem;
      background: var(--bg-surface-2); border: 1px solid var(--border-strong);
      border-radius: 99px; color: var(--text-secondary); cursor: pointer;
      transition: border-color var(--dur), color var(--dur), background var(--dur);
    }
    .quick-pill:hover { border-color: var(--accent); color: var(--accent); background: var(--accent-light); }

    /* ============================================================
       ERROR / STATUS
    ============================================================ */
    .status-bar {
      padding: .9rem 1.25rem;
      border-radius: var(--r-md);
      font-size: .88rem; font-weight: 500;
      display: none; align-items: center; gap: .75rem;
      margin-bottom: 1.5rem;
      animation: fadeIn .3s var(--ease);
    }
    .status-bar.error { background: rgba(192,57,43,.12); border: 1px solid rgba(192,57,43,.3); color: #e57373; display: flex; }
    .status-bar.info  { background: var(--bg-surface-2); border: 1px solid var(--border-strong); color: var(--text-secondary); display: flex; }
    @keyframes fadeIn { from { opacity:0; transform: translateY(-8px); } to { opacity:1; transform:none; } }

    /* ============================================================
       LOADING SKELETON
    ============================================================ */
    .skeleton { border-radius: var(--r-sm); background: var(--bg-surface-2); overflow: hidden; position: relative; }
    .skeleton::after {
      content: ''; position: absolute; inset: 0;
      background: linear-gradient(90deg, transparent 0%, rgba(255,255,255,.04) 50%, transparent 100%);
      animation: shimmer 1.5s infinite;
    }
    @keyframes shimmer { from { transform: translateX(-100%); } to { transform: translateX(100%); } }

    /* ============================================================
       HERO WEATHER CARD
    ============================================================ */
    #weatherDashboard { display: none; animation: dashIn .5s var(--ease) both; }
    @keyframes dashIn { from { opacity:0; transform: translateY(20px); } to { opacity:1; transform:none; } }

    .hero-card {
      background: linear-gradient(135deg, var(--bg-surface) 0%, var(--bg-surface-2) 100%);
      border: 1px solid var(--border-strong);
      border-radius: var(--r-xl);
      padding: 2.5rem;
      box-shadow: var(--shadow-hover);
      position: relative; overflow: hidden;
      margin-bottom: 1.5rem;
    }
    .hero-card::before {
      content: ''; position: absolute; top: -60px; right: -60px;
      width: 300px; height: 300px; border-radius: 50%;
      background: radial-gradient(circle, var(--glow) 0%, transparent 70%);
      pointer-events: none;
    }
    .hero-top {
      display: flex; align-items: flex-start; justify-content: space-between;
      gap: 1.5rem; flex-wrap: wrap; margin-bottom: 2rem;
    }
    .city-info {}
    .city-name {
      font-family: var(--font-display); font-size: clamp(1.8rem, 5vw, 3rem);
      font-weight: 800; letter-spacing: -.03em; line-height: 1.1;
      color: var(--text-primary);
    }
    .city-country { font-size: .88rem; color: var(--text-muted); margin-top: .25rem; }
    .city-time { font-size: .82rem; color: var(--text-muted); margin-top: .35rem; }
    .weather-icon-wrap {
      font-size: 5rem; line-height: 1;
      filter: drop-shadow(0 8px 24px var(--glow));
      animation: float 4s ease-in-out infinite;
      flex-shrink: 0;
    }
    @keyframes float {
      0%,100% { transform: translateY(0); }
      50% { transform: translateY(-10px); }
    }
    .temp-display { display: flex; align-items: flex-end; gap: 1rem; margin-bottom: .75rem; }
    .temp-main {
      font-family: var(--font-display); font-size: clamp(4rem, 10vw, 7rem);
      font-weight: 800; letter-spacing: -.04em; line-height: 1;
      color: var(--text-primary);
    }
    .temp-unit { font-family: var(--font-display); font-size: 2rem; font-weight: 400; color: var(--text-muted); padding-bottom: .75rem; }
    .temp-feels { font-size: .88rem; color: var(--text-secondary); margin-bottom: .5rem; }
    .weather-desc {
      font-size: 1.05rem; font-weight: 500; color: var(--accent);
      text-transform: capitalize; letter-spacing: .01em;
    }
    .hero-divider { height: 1px; background: var(--border-strong); margin: 1.75rem 0; }

    /* Mini stats row */
    .hero-stats { display: flex; gap: 0; flex-wrap: wrap; }
    .hero-stat {
      flex: 1; min-width: 100px; padding: 1rem;
      border-right: 1px solid var(--border);
      display: flex; flex-direction: column; gap: .35rem;
    }
    .hero-stat:last-child { border-right: none; }
    .hero-stat:first-child { padding-left: 0; }
    .stat-icon { font-size: 1.1rem; }
    .stat-val {
      font-family: var(--font-display); font-size: 1.2rem; font-weight: 700;
      color: var(--text-primary);
    }
    .stat-key { font-size: .7rem; font-weight: 600; letter-spacing: .08em; text-transform: uppercase; color: var(--text-muted); }

    /* ============================================================
       METRICS GRID
    ============================================================ */
    .metrics-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
      gap: 1rem;
      margin-bottom: 1.5rem;
    }
    .metric-card {
      background: var(--bg-surface);
      border: 1px solid var(--border-strong);
      border-radius: var(--r-lg);
      padding: 1.5rem;
      box-shadow: var(--shadow-card);
      transition: transform var(--dur), border-color var(--dur), box-shadow var(--dur);
      animation: cardIn .4s var(--ease) both;
      position: relative; overflow: hidden;
    }
    .metric-card:hover { transform: translateY(-3px); box-shadow: var(--shadow-hover); border-color: var(--border-strong); }
    .metric-card::after {
      content: ''; position: absolute; bottom: 0; left: 0; right: 0; height: 2px;
      background: linear-gradient(90deg, var(--accent), var(--accent-dark));
      transform: scaleX(0); transform-origin: left; transition: transform var(--dur);
    }
    .metric-card:hover::after { transform: scaleX(1); }
    @keyframes cardIn {
      from { opacity: 0; transform: translateY(16px); }
      to   { opacity: 1; transform: none; }
    }
    .metric-icon { font-size: 1.4rem; margin-bottom: .75rem; }
    .metric-label { font-size: .68rem; font-weight: 700; letter-spacing: .1em; text-transform: uppercase; color: var(--text-muted); margin-bottom: .35rem; }
    .metric-val { font-family: var(--font-display); font-size: 1.6rem; font-weight: 800; color: var(--text-primary); line-height: 1; margin-bottom: .25rem; }
    .metric-sub { font-size: .78rem; color: var(--text-secondary); }

    /* Progress bar inside metric */
    .metric-bar-track { height: 4px; border-radius: 99px; background: var(--bg-surface-2); margin-top: .75rem; overflow: hidden; }
    .metric-bar-fill { height: 100%; border-radius: 99px; background: linear-gradient(90deg, var(--accent), var(--accent-dark)); transition: width .8s var(--ease); }

    /* ============================================================
       FORECAST ROW
    ============================================================ */
    .forecast-section { margin-bottom: 1.5rem; }
    .section-label {
      display: flex; align-items: center; gap: .5rem;
      font-size: .7rem; font-weight: 700; letter-spacing: .12em; text-transform: uppercase;
      color: var(--accent); margin-bottom: 1rem;
    }
    .section-label::before { content: ''; display: block; width: 18px; height: 2px; background: var(--accent); border-radius: 2px; }
    .forecast-grid { display: flex; gap: .75rem; overflow-x: auto; padding-bottom: .5rem; scrollbar-width: none; }
    .forecast-grid::-webkit-scrollbar { display: none; }
    .forecast-card {
      flex-shrink: 0; min-width: 110px;
      background: var(--bg-surface);
      border: 1px solid var(--border-strong);
      border-radius: var(--r-lg);
      padding: 1.25rem 1rem;
      text-align: center;
      transition: transform var(--dur), border-color var(--dur);
      cursor: default;
      animation: cardIn .4s var(--ease) both;
    }
    .forecast-card:hover { transform: translateY(-3px); border-color: var(--accent); }
    .forecast-card.today { border-color: var(--accent); background: var(--bg-surface-2); }
    .fc-day { font-size: .72rem; font-weight: 700; letter-spacing: .08em; text-transform: uppercase; color: var(--text-muted); margin-bottom: .5rem; }
    .fc-icon { font-size: 1.75rem; margin-bottom: .5rem; line-height: 1; }
    .fc-high { font-family: var(--font-display); font-size: 1.1rem; font-weight: 700; color: var(--text-primary); }
    .fc-low { font-size: .8rem; color: var(--text-muted); margin-top: 2px; }
    .fc-rain { font-size: .7rem; color: #60a5fa; margin-top: .35rem; }

    /* ============================================================
       CODE EXPLAINER — show students the async logic
    ============================================================ */
    .code-section {
      background: var(--bg-surface);
      border: 1px solid var(--border-strong);
      border-radius: var(--r-lg);
      overflow: hidden;
      margin-top: 2rem;
    }
    .code-header {
      padding: 1rem 1.5rem;
      border-bottom: 1px solid var(--border-strong);
      display: flex; align-items: center; justify-content: space-between;
    }
    .code-title { font-family: var(--font-display); font-size: .88rem; font-weight: 700; color: var(--text-secondary); display: flex; align-items: center; gap: .5rem; }
    .code-dot { width: 8px; height: 8px; border-radius: 50%; }
    .code-dots { display: flex; gap: 5px; }
    .code-body {
      padding: 1.5rem;
      font-family: 'Courier New', monospace;
      font-size: .8rem; line-height: 1.8;
      color: var(--text-secondary);
      overflow-x: auto;
      max-height: 320px; overflow-y: auto;
    }
    .kw { color: #c792ea; }
    .fn { color: #82aaff; }
    .str { color: #c3e88d; }
    .cm { color: #546e7a; font-style: italic; }
    .acc { color: var(--accent); }
    .num { color: #f78c6c; }

    /* ============================================================
       REQUEST LOG — shows the API calls being made
    ============================================================ */
    .log-section { margin-top: 1rem; }
    .log-entry {
      display: flex; align-items: center; gap: .75rem;
      padding: .6rem .75rem;
      border-radius: var(--r-sm);
      font-size: .78rem; color: var(--text-muted);
      border-left: 2px solid transparent;
      transition: background var(--dur);
      font-family: 'Courier New', monospace;
    }
    .log-entry.pending { border-color: #f59e0b; color: #f59e0b; background: rgba(245,158,11,.05); }
    .log-entry.success { border-color: #34d399; color: #34d399; background: rgba(52,211,153,.05); }
    .log-entry.error   { border-color: #f87171; color: #f87171; background: rgba(248,113,113,.05); }
    .log-dot { width: 6px; height: 6px; border-radius: 50%; background: currentColor; flex-shrink: 0; animation: blink 1s infinite; }
    .log-entry.success .log-dot, .log-entry.error .log-dot { animation: none; }
    @keyframes blink { 0%,100%{opacity:1} 50%{opacity:.2} }

    /* ============================================================
       FOOTER
    ============================================================ */
    footer {
      border-top: 1px solid var(--border);
      margin-top: 3rem; padding-top: 1.5rem;
      display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 1rem;
    }
    footer p { font-size: .78rem; color: var(--text-muted); }
    .tag-badge {
      font-size: .68rem; font-weight: 700; letter-spacing: .08em; text-transform: uppercase;
      padding: 2px 8px; border-radius: 99px;
      background: var(--accent-light); color: var(--accent);
      border: 1px solid rgba(232,120,74,.2);
    }

    /* ============================================================
       LOADING SPINNER
    ============================================================ */
    .spinner-overlay { display: none; align-items: center; justify-content: center; gap: 1rem; padding: 3rem; }
    .spinner-overlay.show { display: flex; }
    .spinner {
      width: 32px; height: 32px; border-radius: 50%;
      border: 3px solid var(--border-strong);
      border-top-color: var(--accent);
      animation: spin .7s linear infinite;
    }
    @keyframes spin { to { transform: rotate(360deg); } }

    /* ============================================================
       RESPONSIVE
    ============================================================ */
    @media (max-width: 600px) {
      .hero-card { padding: 1.5rem; }
      .hero-stat { padding: .75rem .5rem; min-width: 80px; }
      .metrics-grid { grid-template-columns: 1fr 1fr; }
    }
    @media (max-width: 400px) {
      .metrics-grid { grid-template-columns: 1fr; }
    }

    /* ============================================================
       FOCUS
    ============================================================ */
    :focus-visible { outline: 2px solid var(--accent); outline-offset: 3px; border-radius: var(--r-sm); }
  </style>
</head>
<body>

  <!-- Animated sky background -->
  <div class="sky-bg"></div>
  <div class="stars" id="stars"></div>

  <div class="app-wrap">

    <!-- HEADER -->
    <header class="site-header">
      <div class="logo"><span class="logo-dot" aria-hidden="true"></span>Karthika</div>
      <div class="header-right">
        <a href="updated_index_with_css.html" class="back-link" aria-label="Back to portfolio">← Portfolio</a>
        <div class="unit-toggle" role="group" aria-label="Temperature unit">
          <button class="unit-btn active" data-unit="C" aria-pressed="true">°C</button>
          <button class="unit-btn" data-unit="F" aria-pressed="false">°F</button>
        </div>
      </div>
    </header>

    <!-- PAGE TITLE -->
    <div class="page-eyebrow">
      <span class="eyebrow-dot" aria-hidden="true"></span>
      Async/Await · Fetch API · JSON
    </div>
    <h1 class="page-title">Sky<span class="accent">Watch</span></h1>
    <p class="page-subtitle">Real-time weather dashboard. Demonstrates <code style="font-size:.85em;background:var(--bg-surface-2);padding:1px 6px;border-radius:4px;color:var(--accent)">async/await</code>, the Fetch API, error handling, and dynamic rendering of nested JSON responses.</p>

    <!-- SEARCH -->
    <div class="search-card" role="search">
      <div class="search-input-wrap">
        <span class="search-icon" aria-hidden="true">🔍</span>
        <input
          type="search" id="cityInput" class="search-input"
          placeholder="Search city — e.g. Tokyo, Paris, Mumbai…"
          aria-label="City name" autocomplete="off" spellcheck="false"
        >
      </div>
      <button class="search-btn" id="searchBtn" aria-label="Fetch weather">
        <span id="btnIcon">⚡</span> Get Weather
      </button>
      <div class="quick-cities" role="list" aria-label="Quick city shortcuts">
        <span class="quick-pill" role="listitem" tabindex="0" data-city="Chennai">📍 Chennai</span>
